# Copy this file to .env and fill in your real values.
# .env is git-ignored — it never gets committed.
# On Render, you won't use this file at all: you'll paste these same
# names/values into the Render dashboard's Environment Variables screen instead.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama-3.3-70b-versatile
ATTENDANCE_RADIUS_METERS=200
